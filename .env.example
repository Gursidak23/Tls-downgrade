# TLS Downgrade Analyzer - Security Configuration
# ================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Flask secret key for session signing (REQUIRED - generate a unique one)
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# Admin password hash (bcrypt). Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=CHANGE_ME_GENERATE_A_BCRYPT_HASH

# Session lifetime in minutes
SESSION_LIFETIME_MINUTES=30

# Rate limiting storage (memory:// for dev, redis://host:6379 for production)
RATELIMIT_STORAGE_URI=memory://

# Set to 'production' to enforce HTTPS and strict security headers
FLASK_ENV=development

# Bind address
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
